# Copy to .env before starting (required for Docker Compose + local dev).

NODE_ENV=development
PORT=4000
JWT_SECRET=dev_super_secret_change_me_please_min16

# CORS (dev: allow Next origin + also pass-through)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# SSR fetch helper (server components -> backend)
BACKEND_INTERNAL_URL=http://127.0.0.1:4000

# Postgres (Docker Compose)
POSTGRES_DB=startuphub
POSTGRES_USER=startuphub
POSTGRES_PASSWORD=startuphub_password
POSTGRES_PORT=5432

# Prisma connection string (used by npm run db:migrate on the host)
DATABASE_URL=postgresql://startuphub:startuphub_password@127.0.0.1:5432/startuphub?schema=public

# Seed credentials
SEED_ADMIN_EMAIL=admin@startuphub.local
SEED_ADMIN_PASSWORD=Admin1234!
SEED_USER_EMAIL=user@startuphub.local
SEED_USER_PASSWORD=User1234!
SEED_BUYER_EMAIL=buyer@startuphub.local
SEED_BUYER_PASSWORD=Buyer1234!

